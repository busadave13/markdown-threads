{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "esbuild-watch",
      "type": "shell",
      "command": "npm run esbuild-watch",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "isBackground": true,
      "problemMatcher": "$esbuild-watch",
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "tsc-watch",
      "type": "shell",
      "command": "npm run watch",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": "build"
    },
    {
      "label": "Build VSIX",
      "type": "shell",
      "command": "npm version patch --no-git-tag-version --allow-same-version; Remove-Item -Force ${workspaceFolder}/*.vsix -ErrorAction SilentlyContinue; npx @vscode/vsce package --out ${workspaceFolder}/",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": "build"
    }
  ]
}

