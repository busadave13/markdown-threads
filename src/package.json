{
  "name": "markdown-review-and-comment",
  "displayName": "Markdown: Review & Comment",
  "description": "Inline feedback and comments on markdown files stored in Git",
  "version": "1.0.3",
  "publisher": "busa-dave-13",
  "license": "MIT",
  "icon": "media/markdown-review-comment-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/busadave13/markdown-threads"
  },
  "keywords": [
    "markdown",
    "review",
    "comments",
    "feedback"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:markdownReview.openPreview",
    "onView:markdownReview.files"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markdownReview",
          "title": "Markdown: Review & Comment",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "markdownReview": [
        {
          "id": "markdownReview.files",
          "name": "Markdown Files"
        }
      ]
    },
    "commands": [
      {
        "command": "markdownReview.openPreview",
        "title": "Markdown: Review and Comment",
        "category": "Markdown: Review & Comment",
        "icon": "$(open-preview)"
      },
      {
        "command": "markdownReview.refreshFiles",
        "title": "Refresh",
        "category": "Markdown: Review & Comment",
        "icon": "$(refresh)"
      },
      {
        "command": "markdownReview.selectFolder",
        "title": "Filter by Folder",
        "category": "Markdown: Review & Comment",
        "icon": "$(folder)"
      }
    ],
    "configuration": {
      "title": "Markdown: Review & Comment",
      "properties": {
        "markdownReview.excludeFolders": {
          "type": "array",
          "scope": "resource",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".github",
            ".git",
            "out",
            "dist",
            "bin",
            "obj",
            ".vscode",
            ".vscode-test"
          ],
          "description": "Folders to exclude from the Markdown Files tree view."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "markdownReview.openPreview",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "markdownReview.openPreview",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "markdownReview.selectFolder",
          "when": "view == markdownReview.files",
          "group": "navigation@1"
        },
        {
          "command": "markdownReview.refreshFiles",
          "when": "view == markdownReview.files",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-production",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "esbuild": "node esbuild.config.mjs",
    "esbuild-production": "node esbuild.config.mjs --production",
    "esbuild-watch": "node esbuild.config.mjs --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint . --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "npm run esbuild-production && vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.55.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "markdown-it": "^14.1.1",
    "simple-git": "^3.21.0",
    "uuid": "^9.0.1"
  }
}
